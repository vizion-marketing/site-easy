---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.tsx";
import Hero from "../components/Hero.tsx";
import LatestTours from "../components/LatestTours.tsx";
import AboutBento from "../components/AboutBento.tsx";
import VirtualTourPilot from "../components/VirtualTourPilot.tsx";
import Specificites from "../components/Specificites.tsx";
import UseCases from "../components/UseCases.tsx";
import SecteursBenefices from "../components/SecteursBenefices.tsx";
import ProcessTimeline from "../components/ProcessTimeline.tsx";
import Franchises from "../components/Franchises.tsx";
import TestimonialsWall from "../components/TestimonialsWall.tsx";
import ContactCTA from "../components/ContactCTA.tsx";
import FAQ from "../components/FAQ.tsx";
import ContactVideoDock from "../components/ContactVideoDock.tsx";
import { sanityClient } from "sanity:client";
import { urlFor } from "../sanity/lib/image";
import { geocodeAll } from "../sanity/lib/geocode";
import { franchiseLocatorSeed } from "../lib/franchise-locator";
import {
  ALL_TOURS_QUERY,
  SECTEURS_QUERY,
  CAS_USAGES_QUERY,
  FRANCHISEES_QUERY,
  FAQ_QUERY,
  TESTIMONIALS_QUERY,
} from "../sanity/lib/queries";

type TourDoc = {
  _id: string;
  title?: string;
  slug?: { current?: string };
  client?: string;
  clientLogo?: unknown;
  location?: string;
  secteur?: string;
  casUsages?: string[];
  description?: string;
  coverImage?: unknown;
  tourUrl?: string;
};

// Taxonomie de menu (secteur d'activité / cas d'usage).
type TaxDoc = {
  _id: string;
  title?: string;
  slug?: string;
  description?: string;
  icon?: string;
};

// Récupération des dernières visites virtuelles depuis Sanity (tolérante :
// placeholders de démo si la config Sanity n'est pas prête ou s'il n'y a aucune visite).
let tourDocs: TourDoc[] = [];
try {
  tourDocs = await sanityClient.fetch<TourDoc[]>(ALL_TOURS_QUERY);
} catch (err) {
  console.warn("[index] Échec du fetch Sanity des visites — placeholders utilisés.", err);
}

const tours = (tourDocs ?? []).slice(0, 8).map((t) => ({
  title: t.title ?? "Visite virtuelle",
  client: t.client,
  clientLogo: t.clientLogo ? urlFor(t.clientLogo).width(240).url() : null,
  location: t.location,
  // Badge de la carte = 1er secteur tagué.
  category: t.secteur,
  imageUrl: t.coverImage
    ? urlFor(t.coverImage).width(640).height(400).fit("crop").url()
    : null,
  // Pas encore de route /visites/[slug] : on pointe sur l'embed s'il existe, sinon ancre.
  href: t.tourUrl ?? "#visites",
  // Cas d'usage principal (1er tag) + mini description (texte brut du blockContent).
  useCase: t.casUsages?.[0],
  description: t.description,
}));

// Taxonomies du méga-menu (tags des visites). Tolérant : si Sanity n'est pas prêt
// ou qu'aucun tag n'est saisi, le Navbar bascule sur ses valeurs par défaut.
async function fetchTaxonomy(query: string, label: string): Promise<TaxDoc[]> {
  try {
    return (await sanityClient.fetch<TaxDoc[]>(query)) ?? [];
  } catch (err) {
    console.warn(`[index] Échec du fetch Sanity ${label} — défauts utilisés.`, err);
    return [];
  }
}

const toMenuItems = (docs: TaxDoc[]) =>
  docs
    .filter((d) => d.title)
    .map((d) => ({
      title: d.title as string,
      desc: d.description ?? "",
      icon: d.icon ?? "",
      href: d.slug ? `#${d.slug}` : "#",
    }));

const secteurs = toMenuItems(await fetchTaxonomy(SECTEURS_QUERY, "des secteurs"));
const casUsages = toMenuItems(await fetchTaxonomy(CAS_USAGES_QUERY, "des cas d'usage"));

// Logos client de démonstration (« logoipsum ») — SVG inline en data URI, filtrés en
// blanc sur la carte. À remplacer par les vrais logos via le champ clientLogo (Studio).
// NB : concaténation de chaînes (et non template literal imbriqué) — un backtick
// imbriqué dans le frontmatter casse le scanner du compilateur Astro.
const logoipsum = (mark: string, label: string) =>
  "data:image/svg+xml," +
  encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 220 40">' +
      mark +
      '<text x="48" y="27" font-family="Arial, Helvetica, sans-serif" font-size="20" font-weight="700" fill="#111">' +
      label +
      "</text></svg>",
  );
const DEMO_LOGOS = [
  logoipsum('<path d="M20 6 34 20 20 34 6 20Z" fill="#111"/>', "Logoipsum"),
  logoipsum('<path d="M12 8 33 20 12 32Z" fill="#111"/>', "logoipsum"),
  logoipsum('<path d="M20 6 33 13v14l-13 7-13-7V13Z" fill="#111"/>', "LOGOIPSUM"),
  logoipsum('<circle cx="20" cy="20" r="13" fill="#111"/>', "Logoipsum"),
];

// Données de démonstration tant qu'aucune visite n'est saisie dans le Studio (/admin).
const placeholderTours = [
  { title: "Villa Horizon", client: "Barnes", location: "Cannes", category: "Immobilier", useCase: "Génération de lead", description: "Une villa d'exception mise en scène en 360° pour capter des acheteurs qualifiés avant la première visite.", imageUrl: "https://picsum.photos/seed/villa/640/400", href: "#visites", testimonial: { quote: "La visite 360° a divisé par deux nos visites physiques inutiles : seuls les acheteurs vraiment décidés se déplacent.", author: "Camille Rousseau", role: "Directrice, Barnes Côte d'Azur", avatar: "https://i.pravatar.cc/96?img=47" } },
  { title: "Hôtel Le Belvédère", client: "Groupe Accor", location: "Annecy", category: "Hôtellerie", useCase: "Expérience innovante", description: "Chambres, spa et vues sur le lac : une visite immersive qui donne envie de réserver.", imageUrl: "https://picsum.photos/seed/hotel/640/400", href: "#visites" },
  { title: "Showroom Atelier 9", client: "Maison Dôme", location: "Paris 8e", category: "Retail", useCase: "Expérience innovante", description: "Un showroom explorable 24h/24, fiches produits intégrées directement au parcours.", imageUrl: "https://picsum.photos/seed/showroom/640/400", href: "#visites" },
  { title: "Musée des Arts", client: "Ville de Lyon", location: "Lyon", category: "Culture", useCase: "Expérience innovante", description: "Le parcours des collections en accès libre, pour préparer ou prolonger la visite sur place.", imageUrl: "https://picsum.photos/seed/musee/640/400", href: "#visites" },
  { title: "Résidence Les Pins", client: "Nexity", location: "Bordeaux", category: "Immobilier", useCase: "Qualification de leads", description: "Programme neuf visitable à distance : seuls les acquéreurs décidés se déplacent.", imageUrl: "https://picsum.photos/seed/residence/640/400", href: "#visites" },
  { title: "Camping Bord de Mer", client: "Huttopia", location: "Biarritz", category: "Tourisme", useCase: "Génération de lead", description: "Emplacements et hébergements en 360° pour booster les réservations en ligne.", imageUrl: "https://picsum.photos/seed/camping/640/400", href: "#visites" },
  { title: "Espace Coworking Nova", client: "Wojo", location: "Nantes", category: "Bureaux", useCase: "Marque employeur", description: "Espaces de travail et services présentés en immersion pour séduire de nouveaux membres.", imageUrl: "https://picsum.photos/seed/coworking/640/400", href: "#visites" },
  { title: "Boutique Flagship", client: "Le Slip Français", location: "Marseille", category: "Retail", useCase: "Expérience innovante", description: "Le flagship en visite interactive, prolongement digital de l'expérience en magasin.", imageUrl: "https://picsum.photos/seed/boutique/640/400", href: "#visites" },
].map((t, i) => ({ ...t, clientLogo: DEMO_LOGOS[i % DEMO_LOGOS.length] }));

const displayTours = tours.length ? tours : placeholderTours;

// Sélection « coup de cœur » mise en avant dans la section bento (3 visites).
// La 1re est la grande tuile featured (gauche), les 2 suivantes sont empilées à droite.
// TODO : remplacer les imageUrl placeholder par les vraies coverImages (Studio /admin).
const coupDeCoeurTours = [
  {
    title: "Le musée imaginaire d'Oli",
    category: "Culture",
    imageUrl: "https://picsum.photos/seed/musee-imaginaire-oli/900/1100",
    href: "#visites",
  },
  {
    title: "Le lycée entre Meurthe et Sanon",
    category: "Éducation",
    location: "Dombasle-sur-Meurthe",
    imageUrl: "https://picsum.photos/seed/lycee-meurthe-sanon/900/600",
    href: "#visites",
  },
  {
    title: "Le magasin école pour McDonald's",
    client: "McDonald's",
    category: "Formation",
    imageUrl: "https://picsum.photos/seed/magasin-ecole-mcdonalds/900/600",
    href: "#visites",
  },
  // 2 placeholders — à remplacer par de vraies visites (Studio /admin).
  {
    title: "Hôtel Le Belvédère",
    category: "Hôtellerie",
    location: "Annecy",
    imageUrl: "https://picsum.photos/seed/hotel-belvedere/900/600",
    href: "#visites",
  },
  {
    title: "Showroom Atelier 9",
    category: "Retail",
    location: "Paris 8e",
    imageUrl: "https://picsum.photos/seed/showroom-atelier-9/900/600",
    href: "#visites",
  },
];

// Réseau de franchisés (section moteur de recherche + portrait dynamique).
// Tolérant : franchisés de démo tant qu'aucun document n'est saisi dans le Studio.
type FranchiseeDoc = {
  _id: string;
  prenom?: string;
  nom?: string;
  zone?: string;
  photo?: unknown;
  pageLink?: string;
  ville?: string;
  codePostal?: string;
  adresse?: string;
  description?: string;
  noteGoogle?: number;
  avisGoogle?: number;
  ficheGoogle?: string;
  reseaux?: Array<{ plateforme?: string; url?: string }>;
};

let franchiseeDocs: FranchiseeDoc[] = [];
try {
  franchiseeDocs = await sanityClient.fetch<FranchiseeDoc[]>(FRANCHISEES_QUERY);
} catch (err) {
  console.warn("[index] Échec du fetch Sanity des franchisés — placeholders utilisés.", err);
}

const mappedFranchisees = (franchiseeDocs ?? [])
  .filter((f) => f.prenom || f.nom)
  .map((f) => ({
    id: f._id,
    name: [f.prenom, f.nom].filter(Boolean).join(" "),
    zone: f.zone ?? "",
    ville: f.ville ?? "",
    imageUrl: f.photo
      ? urlFor(f.photo).width(800).height(1000).fit("crop").url()
      : null,
    pageLink: f.pageLink,
    // Vitrine du store locator (encart sur la photo) — affichage conditionnel côté client.
    description: f.description,
    googleRating: f.noteGoogle,
    googleReviews: f.avisGoogle,
    gmbUrl: f.ficheGoogle,
    socials: (f.reseaux ?? [])
      .filter((r) => r.plateforme && r.url)
      .map((r) => ({ platform: r.plateforme as string, url: r.url as string })),
    // champs d'adresse — servent au géocodage au build puis sont retirés du payload client
    adresse: f.adresse,
    codePostal: f.codePostal,
  }));

// Source : documents Sanity s'il y en a, sinon le réseau réel (src/lib/franchises.ts).
const franchiseeSeed: Array<{
  id: string;
  name: string;
  zone: string;
  ville: string;
  imageUrl: string | null;
  pageLink?: string;
  description?: string;
  googleRating?: number;
  googleReviews?: number;
  gmbUrl?: string;
  socials?: Array<{ platform: string; url: string }>;
  adresse?: string | null;
  codePostal?: string | null;
}> = mappedFranchisees.length ? mappedFranchisees : franchiseLocatorSeed();

// Géocodage au BUILD via la Base Adresse Nationale → ajoute { lat, lng } (null si non localisable).
const geocoded = await geocodeAll(franchiseeSeed);
// On retire les champs d'adresse bruts avant de transmettre au composant client.
const displayFranchisees = geocoded.map(({ adresse, codePostal, ...rest }) => rest);

// Témoignages clients (marquee sous « Dernières visites virtuelles »).
// Tolérant : placeholders de démo tant qu'aucun témoignage n'est saisi dans le Studio.
type TestimonialDoc = {
  _id: string;
  quote?: string;
  author?: string;
  role?: string;
  company?: string;
  agency?: string;
  avatar?: unknown;
  rating?: number;
};

let testimonialDocs: TestimonialDoc[] = [];
try {
  testimonialDocs = await sanityClient.fetch<TestimonialDoc[]>(TESTIMONIALS_QUERY);
} catch (err) {
  console.warn("[index] Échec du fetch Sanity des témoignages — placeholders utilisés.", err);
}

const testimonialsData = (testimonialDocs ?? [])
  .filter((t) => t.quote && t.author)
  .map((t) => ({
    quote: t.quote as string,
    author: t.author as string,
    role: t.role,
    company: t.company,
    agency: t.agency,
    avatar: t.avatar ? urlFor(t.avatar).width(96).height(96).fit("crop").url() : null,
    rating: t.rating,
  }));

// Placeholders de démo — avatars laissés à `null` : la carte affiche alors la pastille
// d'initiales (repli neutre, sans dépendance externe) en attendant les vraies photos.
const placeholderTestimonials = [
  { quote: "La visite 360° a complètement changé notre prise de mandats : les vendeurs nous confient leur bien en voyant le rendu, et les acheteurs arrivent déjà convaincus.", author: "Camille Laurent", role: "Directrice d'agence", company: "Barnes Côte d'Azur", agency: "easyvirtual.tours PACA", avatar: null, rating: 5 },
  { quote: "Mise en ligne en 48h, accompagnement au top. Nos chambres et le spa se vendent désormais en ligne avant même l'arrivée des clients.", author: "Thomas Mercier", role: "Directeur", company: "Hôtel Le Belvédère", agency: "easyvirtual.tours Annecy", avatar: null, rating: 5 },
  { quote: "Un showroom visitable 24h/24, c'est un commercial qui ne dort jamais. Le taux de prise de contact a doublé en trois mois.", author: "Sofia Benali", role: "Responsable retail", company: "Maison Dôme", agency: "easyvirtual.tours Paris", avatar: null, rating: 5 },
  { quote: "Qualité Matterport irréprochable et un réseau local vraiment réactif. On sent la différence avec une simple captation photo.", author: "Hugo Lefèvre", role: "Promoteur", company: "Nexity", agency: "easyvirtual.tours Bordeaux", avatar: null, rating: 5 },
  { quote: "Nos visiteurs préparent leur venue grâce à la visite virtuelle du musée. C'est devenu un outil de médiation à part entière.", author: "Léa Dubois", role: "Chargée de projets", company: "Ville de Lyon", agency: "easyvirtual.tours Lyon", avatar: null, rating: 5 },
  { quote: "Le rapport conseil / réalisation est ce qui m'a convaincu : easyvirtual.tours pense la visite comme un outil commercial, pas juste un joli rendu.", author: "Antoine Roux", role: "Gérant", company: "Camping Bord de Mer", agency: "easyvirtual.tours Biarritz", avatar: null, rating: 5 },
];

const displayTestimonials = testimonialsData.length ? testimonialsData : placeholderTestimonials;

// FAQ — questions/réponses depuis Sanity (ordre `order`). Tolérant : si Sanity n'est
// pas prêt ou qu'aucune question n'est saisie, la FAQ retombe sur ses défauts internes.
type FaqDoc = { question?: string; answer?: string };
let faqDocs: FaqDoc[] = [];
try {
  faqDocs = await sanityClient.fetch<FaqDoc[]>(FAQ_QUERY);
} catch (err) {
  console.warn("[index] Échec du fetch Sanity de la FAQ — défauts utilisés.", err);
}
const faqItems = (faqDocs ?? [])
  .filter((f) => f.question && f.answer)
  .map((f) => ({ question: f.question as string, answer: f.answer as string }));
---

<BaseLayout>
  <Navbar client:load tours={displayTours} secteurs={secteurs} casUsages={casUsages} />
  <Hero client:visible />
  <AboutBento client:visible />
  <VirtualTourPilot client:visible />
  <UseCases client:visible />
  <ProcessTimeline client:visible />
  <SecteursBenefices client:visible />
  <Specificites />
  <LatestTours client:visible tours={coupDeCoeurTours} />
  <TestimonialsWall client:visible testimonials={displayTestimonials} />
  <Franchises client:visible franchisees={displayFranchisees} />
  <ContactCTA client:visible />
  <FAQ client:visible items={faqItems} />
  <ContactVideoDock client:idle />
</BaseLayout>
