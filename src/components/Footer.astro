---
// Footer global du site — composant Astro statique (aucun JS client).
// Fond blanc dominant, accent orange #FF6600 réservé aux survols / au point de la
// marque / aux chips d'icônes. Données branchées au singleton Sanity `siteSettings`
// (tolérant : défauts FR si le Studio n'est pas prêt / champs vides).
import { sanityClient } from "sanity:client";
import { SITE_SETTINGS_QUERY } from "../sanity/lib/queries";

type SiteSettings = {
  title?: string;
  email?: string;
  phone?: string;
  social?: {
    linkedin?: string;
    instagram?: string;
    facebook?: string;
    youtube?: string;
    twitter?: string;
  };
};

let settings: SiteSettings | null = null;
try {
  settings = await sanityClient.fetch<SiteSettings>(SITE_SETTINGS_QUERY);
} catch (err) {
  console.warn("[Footer] Échec du fetch Sanity des paramètres — défauts utilisés.", err);
}

const email = settings?.email ?? "contact@easyvirtual.tours";
const phone = settings?.phone ?? "+33 (0)1 84 80 00 00";
const phoneTel = "tel:" + phone.replace(/[^+\d]/g, "");
const social = settings?.social ?? {};
const year = new Date().getFullYear();

// Colonnes de navigation — ancres pointées sur les sections existantes de la home.
const COLUMNS = [
  {
    title: "Solutions",
    links: [
      { label: "Immobilier", href: "#visites" },
      { label: "Hôtellerie", href: "#visites" },
      { label: "Commerce", href: "#visites" },
      { label: "Culture", href: "#visites" },
      { label: "Tourisme", href: "#visites" },
    ],
  },
  {
    title: "Cas d'usage",
    links: [
      { label: "Vendre un bien", href: "#cas-dusages" },
      { label: "Recruter", href: "#cas-dusages" },
      { label: "Former", href: "#cas-dusages" },
      { label: "Promouvoir", href: "#cas-dusages" },
    ],
  },
  {
    title: "Entreprise",
    links: [
      { label: "À propos", href: "#a-propos" },
      { label: "Le réseau", href: "#franchises" },
      { label: "Devenir franchisé", href: "#franchises" },
      { label: "Contact", href: "#contact" },
    ],
  },
  {
    title: "Ressources",
    links: [
      { label: "Réalisations", href: "#visites" },
      { label: "Comment ça se passe", href: "#comment-ca-se-passe" },
      { label: "FAQ", href: "#faq" },
      { label: "Mentions légales", href: "#mentions-legales" },
    ],
  },
];

const LEGAL = [
  { label: "Mentions légales", href: "#mentions-legales" },
  { label: "Politique de confidentialité", href: "#confidentialite" },
  { label: "CGV", href: "#cgv" },
];

// Réseaux sociaux — icônes SVG inline (paths), href par défaut « # » si non renseigné.
const SOCIALS = [
  {
    label: "LinkedIn",
    href: social.linkedin ?? "#",
    path: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M4 2a2 2 0 1 1-2 2 2 2 0 0 1 2-2z",
  },
  {
    label: "Instagram",
    href: social.instagram ?? "#",
    path: "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z M17.5 6.5h.01 M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9a5.5 5.5 0 0 1-5.5 5.5h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2z",
  },
  {
    label: "YouTube",
    href: social.youtube ?? "#",
    path: "M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2C5.12 19.5 12 19.5 12 19.5s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z M9.75 15.02V8.48L15.5 11.75l-5.75 3.27z",
  },
  {
    label: "Facebook",
    href: social.facebook ?? "#",
    path: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
  },
];
---

<footer class="w-full border-t border-[#e5e7eb] bg-white">
  <div class="mx-auto w-full max-w-[var(--container)] px-6 sm:px-8">

    {/* RANGÉE HAUTE — grille asymétrique : marque (gauche) + colonnes de liens (droite) */}
    <div class="grid grid-cols-1 gap-16 pt-20 pb-16 lg:grid-cols-12 lg:gap-8">

      {/* BLOC MARQUE */}
      <div class="flex flex-col items-start gap-8 lg:col-span-4">
        <div class="flex flex-col gap-4">
          <a href="/" class="font-heading text-2xl font-bold tracking-tight text-[#0a0a0a] transition-opacity hover:opacity-90">
            easyvirtual<span class="text-[#FF6600]">.</span>tours
          </a>
          <p class="max-w-xs text-sm leading-relaxed text-gray-600">
            Le spécialiste français des visites virtuelles 360° immersives. On met
            en valeur vos espaces — immobilier, hôtellerie, commerce, culture — partout en France.
          </p>
        </div>

        {/* Réseaux sociaux — pastilles qui se remplissent en orange au survol */}
        <div class="flex items-center gap-3">
          {SOCIALS.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex h-10 w-10 items-center justify-center rounded-full border border-[#e5e7eb] text-gray-500 transition-all duration-300 hover:border-[#FF6600] hover:bg-[#FF6600] hover:text-white active:scale-90"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform group-hover:scale-110"
                aria-hidden="true"
              >
                <path d={s.path}></path>
              </svg>
            </a>
          ))}
        </div>
      </div>

      {/* COLONNES DE LIENS */}
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 lg:col-span-8">
        {COLUMNS.map((col) => (
          <div class="flex flex-col gap-6">
            <span class="text-[11px] font-bold uppercase tracking-[0.15em] text-gray-400">{col.title}</span>
            <ul class="flex flex-col gap-3">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-gray-600 transition-colors hover:text-[#FF6600]">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    {/* BANDE CONTACT */}
    <div class="border-t border-[#e5e7eb] py-8">
      <div class="flex flex-col flex-wrap items-start gap-8 md:flex-row md:items-center md:gap-12">

        {/* Email */}
        <a href={`mailto:${email}`} class="group flex items-center gap-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#fff4ec] text-[#FF6600] transition-transform duration-300 group-hover:scale-105">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
          </span>
          <span class="flex flex-col">
            <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">Email</span>
            <span class="text-sm font-medium text-[#0a0a0a] transition-colors group-hover:text-[#FF6600]">{email}</span>
          </span>
        </a>

        {/* Téléphone */}
        <a href={phoneTel} class="group flex items-center gap-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#fff4ec] text-[#FF6600] transition-transform duration-300 group-hover:scale-105">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </span>
          <span class="flex flex-col">
            <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">Téléphone</span>
            <span class="text-sm font-medium text-[#0a0a0a] transition-colors group-hover:text-[#FF6600]">{phone}</span>
          </span>
        </a>

        {/* Couverture */}
        <div class="flex items-center gap-4">
          <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#fff4ec] text-[#FF6600]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </span>
          <span class="flex flex-col">
            <span class="text-[10px] font-bold uppercase tracking-wider text-gray-400">Couverture</span>
            <span class="text-sm font-medium text-[#0a0a0a]">Partout en France</span>
          </span>
        </div>

      </div>
    </div>

    {/* BARRE BASSE */}
    <div class="flex flex-col items-center justify-between gap-6 border-t border-[#e5e7eb] py-8 sm:flex-row">
      <p class="text-[11px] font-medium text-gray-400">
        © {year} easyvirtual.tours — Tous droits réservés.
      </p>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {LEGAL.map((link) => (
          <a href={link.href} class="text-[11px] font-medium text-gray-400 transition-colors hover:text-[#FF6600]">
            {link.label}
          </a>
        ))}
      </div>
    </div>

  </div>
</footer>
